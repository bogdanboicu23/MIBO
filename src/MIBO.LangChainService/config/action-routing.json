{
  "routes": [
    {
      "actionType": "shop.search",
      "mode": "tool",
      "tool": "shop.searchProducts",
      "argTemplate": {
        "limit": 12,
        "skip": 0
      },
      "argMap": {
        "query": "q",
        "q": "q",
        "limit": "limit",
        "skip": "skip"
      },
      "patchPath": "/data/shop.searchProducts",
      "patchAliases": [
        "/data/shop.listProducts"
      ]
    },
    {
      "actionType": "shop.select_category",
      "mode": "tool",
      "tool": "shop.listProductsByCategory",
      "argTemplate": {
        "limit": 12,
        "skip": 0
      },
      "argMap": {
        "category": "category",
        "slug": "category",
        "limit": "limit",
        "skip": "skip"
      },
      "patchPath": "/data/shop.listProductsByCategory",
      "patchAliases": [
        "/data/shop.searchProducts",
        "/data/shop.listProducts"
      ]
    },
    {
      "actionType": "shop.open_product",
      "mode": "tool",
      "tool": "shop.getProduct",
      "argMap": {
        "productId": "id",
        "id": "id"
      },
      "patchPath": "/data/shop.getProduct"
    },
    {
      "actionType": "shop.change_page",
      "mode": "tool",
      "tool": "shop.listProducts",
      "toolCandidates": [
        {
          "tool": "shop.searchProducts",
          "whenPayloadHasAny": [
            "query",
            "q"
          ]
        },
        {
          "tool": "shop.listProductsByCategory",
          "whenPayloadHasAny": [
            "category",
            "slug"
          ]
        }
      ],
      "argTemplate": {
        "limit": 12,
        "skip": 0
      },
      "argMap": {
        "query": "q",
        "q": "q",
        "category": "category",
        "slug": "category",
        "limit": "limit",
        "skip": "skip"
      },
      "patchPath": "/data/{tool}",
      "patchAliases": [
        "/data/shop.listProducts",
        "/data/shop.searchProducts",
        "/data/shop.listProductsByCategory"
      ]
    },
    {
      "actionType": "shop.sort",
      "mode": "tool",
      "tool": "shop.listProductsSorted",
      "argTemplate": {
        "sortBy": "rating",
        "order": "desc",
        "limit": 12,
        "skip": 0
      },
      "argMap": {
        "sortBy": "sortBy",
        "order": "order",
        "sort": "sort",
        "limit": "limit",
        "skip": "skip"
      },
      "patchPath": "/data/shop.listProductsSorted",
      "patchAliases": [
        "/data/shop.searchProducts",
        "/data/shop.listProducts"
      ]
    },
    {
      "actionType": "finance.change_period",
      "mode": "tool",
      "tool": "finance.getExpenseAnalytics",
      "argTemplate": {
        "period": "last30days"
      },
      "argMap": {
        "period": "period",
        "startDate": "startDate",
        "endDate": "endDate"
      },
      "patchPath": "/data/finance.getExpenseAnalytics"
    },
    {
      "actionType": "finance.filter_transactions",
      "mode": "tool",
      "tool": "finance.getTransactions",
      "argTemplate": {
        "skip": 0,
        "limit": 30
      },
      "argMap": {
        "type": "type",
        "category": "category",
        "startDate": "startDate",
        "endDate": "endDate",
        "sortBy": "sortBy",
        "order": "order",
        "skip": "skip",
        "limit": "limit"
      },
      "patchPath": "/data/finance.getTransactions"
    },

    {
      "actionType": "shop.checkout",
      "mode": "prompt",
      "promptTemplate": "Finalizează checkout pentru cartId={{cartId}} și actualizează rezumatul de cumpărături."
    },
    {
      "actionType": "ui.refine",
      "mode": "prompt",
      "promptTemplate": "Rafinează răspunsul UI pentru contextul curent și păstrează componentele interactive."
    },
    {
      "actionType": "ui.expand",
      "mode": "prompt",
      "promptTemplate": "Extinde analiza și compune UI cu componente suplimentare interconectate."
    },
    {
      "actionType": "ui.action",
      "mode": "prompt",
      "promptTemplate": "Execută acțiunea UI generică cu contextul curent și payload: {{payload}}"
    },
    {
      "actionType": "ui.form.submit",
      "mode": "prompt",
      "promptTemplate": "Procesează formularul trimis ({{values}}) și actualizează UI-ul cu pașii următori."
    },
    {
      "actionType": "ui.timeline.select",
      "mode": "prompt",
      "promptTemplate": "Detaliază evenimentul selectat din timeline și actualizează UI-ul contextual."
    },

    {
      "actionType": "shop.add_to_cart",
      "mode": "tool",
      "tool": "shop.addToCart",
      "argMap": {
        "userId": "userId",
        "products": "products"
      },
      "patchPath": "/data/shop.addToCart",
      "publish": {
        "subject": "shop.cart_updated",
        "fromToolResultJsonPath": {
          "cartId": "$.id",
          "total": "$.total",
          "discountedTotal": "$.discountedTotal",
          "totalProducts": "$.totalProducts",
          "totalQuantity": "$.totalQuantity"
        },
        "fixed": {
          "sourceType": "shop.addToCart"
        }
      }
    },
    {
      "actionType": "shop.view_cart",
      "mode": "tool",
      "tool": "shop.getCart",
      "argMap": {
        "cartId": "cartId"
      },
      "patchPath": "/data/shop.getCart"
    }
  ]
}
