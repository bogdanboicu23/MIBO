# Required
GROQ_API_KEY=

# Optional model settings
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_TIMEOUT_SECONDS=20
GROQ_MAX_TOKENS=1200

# Planner behavior
PLANNER_MAX_STEPS=8
PLANNER_REPAIR_ATTEMPTS=2
ENABLE_DEEP_REASONING=true

# Deep search tuning
DEEP_SEARCH_MAX_TOOLS=12
DEEP_SEARCH_MAX_COMPONENTS=8
DEEP_SEARCH_MAX_ACTION_ROUTES=8

# Context path inside container
CONTEXT_CONFIG_DIR=/app/config

# External context (comma-separated hosts supported by pydantic list parsing if provided as JSON)
# EXTERNAL_CONTEXT_ALLOWED_HOSTS=["api.example.com","knowledge.example.com"]
EXTERNAL_CONTEXT_MAX_URLS=3
EXTERNAL_CONTEXT_TIMEOUT_SECONDS=5
EXTERNAL_CONTEXT_MAX_CHARS=1200

# Memory
MEMORY_PROMPT_WINDOW=8
MEMORY_PLAN_WINDOW=8
MEMORY_SUMMARY_CHAR_LIMIT=1200

# Service port
PORT=8088
