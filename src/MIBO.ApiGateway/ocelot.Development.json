{
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:8080"
  },
  "Routes": [
    // -------------------------
    // AUTH
    // -------------------------
    {
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5001 }
      ],
      "UpstreamPathTemplate": "/api/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "RouteIsCaseSensitive": false
    },

    // -------------------------
    // USERS (identity service)
    // -------------------------
    {
      "DownstreamPathTemplate": "/api/users/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5001 }
      ],
      "UpstreamPathTemplate": "/api/users/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "RouteIsCaseSensitive": false
    },

    // -------------------------
    // CONVERSATION SERVICE
    // -------------------------
    {
      "DownstreamPathTemplate": "/api/chat",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 7251 }
      ],
      "UpstreamPathTemplate": "/api/chat",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ],
      "DangerousAcceptAnyServerCertificateValidator": true,
      "RouteIsCaseSensitive": false
    },
    {
      "DownstreamPathTemplate": "/api/v1/chat",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 7251 }
      ],
      "UpstreamPathTemplate": "/api/v1/chat",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ],
      "DangerousAcceptAnyServerCertificateValidator": true,
      "RouteIsCaseSensitive": false
    },
    {
      "DownstreamPathTemplate": "/api/v1/conversations",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 7251 }
      ],
      "UpstreamPathTemplate": "/api/v1/conversations",
      "UpstreamHttpMethod": [ "GET", "POST", "OPTIONS" ],
      "DangerousAcceptAnyServerCertificateValidator": true,
      "RouteIsCaseSensitive": false
    },
    {
      "DownstreamPathTemplate": "/api/v1/conversations/{conversationId}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 7251 }
      ],
      "UpstreamPathTemplate": "/api/v1/conversations/{conversationId}",
      "UpstreamHttpMethod": [ "GET", "PATCH", "DELETE", "OPTIONS" ],
      "DangerousAcceptAnyServerCertificateValidator": true,
      "RouteIsCaseSensitive": false
    },
    // -------------------------
    // ACTION SERVICE
    // -------------------------
    {
      "DownstreamPathTemplate": "/api/actions/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5288 }
      ],
      "UpstreamPathTemplate": "/api/actions/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS" ],
      "RouteIsCaseSensitive": false
    },

    // -------------------------
    // VISUALISATION
    // -------------------------
    {
      "DownstreamPathTemplate": "/api/visualisation/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5003 }
      ],
      "UpstreamPathTemplate": "/api/visualisation/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "RouteIsCaseSensitive": false
    },

    // -------------------------
    // CALENDAR
    // -------------------------
    {
      "DownstreamPathTemplate": "/api/calendar/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5004 }
      ],
      "UpstreamPathTemplate": "/api/calendar/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "RouteIsCaseSensitive": false
    }
  ]
}
